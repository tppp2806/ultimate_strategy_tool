+
+/* 固定计划占比组合回测 */
+.backtest-portfolio-box {
+  grid-column: 1 / -1;
+  display: grid;
+  gap: 10px;
+  padding: 12px 13px;
+  border: 1px solid var(--line);
+  border-radius: 17px;
+  background: rgba(255,255,255,.54);
+}
+.portfolio-head,
+.portfolio-actions {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 8px;
+  flex-wrap: wrap;
+}
+.inline-check.strong {
+  display: inline-flex;
+  align-items: center;
+  gap: 6px;
+  margin: 0;
+  font-weight: 950;
+  color: var(--ink);
+}
+.portfolio-items {
+  display: grid;
+  gap: 8px;
+}
+.portfolio-empty {
+  padding: 12px;
+  border: 1px dashed var(--line);
+  border-radius: 14px;
+  color: var(--muted);
+  background: rgba(255,250,242,.7);
+  font-size: 13px;
+}
+.portfolio-item-row {
+  display: grid;
+  grid-template-columns: minmax(96px, .85fr) minmax(150px, 1.2fr) minmax(76px, .58fr) minmax(82px, .62fr) minmax(108px, .8fr) minmax(98px, .65fr) auto;
+  gap: 7px;
+  align-items: end;
+  padding: 9px;
+  border: 1px solid rgba(143, 95, 54, .18);
+  border-radius: 14px;
+  background: #fffaf2;
+}
+.portfolio-item-row label {
+  display: grid;
+  gap: 4px;
+  min-width: 0;
+  margin: 0;
+}
+.portfolio-item-row label span {
+  font-size: 11px;
+  font-weight: 900;
+  color: var(--muted);
+}
+.portfolio-item-row input,
+.portfolio-item-row select {
+  width: 100%;
+  min-width: 0;
+  height: 34px;
+  padding: 0 8px;
+  border: 1px solid var(--line);
+  border-radius: 10px;
+  background: #fffdfa;
+}
+.portfolio-remove {
+  min-height: 34px;
+  padding: 0 10px;
+  color: var(--red);
+}
+@media (max-width: 860px) {
+  .portfolio-item-row {
+    grid-template-columns: repeat(2, minmax(0, 1fr));
+  }
+  .portfolio-remove {
+    grid-column: 1 / -1;
+  }
+}
